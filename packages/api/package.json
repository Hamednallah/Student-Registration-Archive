{
    "name": "@psau/api",
    "version": "1.0.0",
    "main": "dist/server.js",
    "scripts": {
        "build": "tsc",
        "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
        "start": "node dist/index.js",
        "test": "vitest run",
        "type-check": "tsc --noEmit",
        "db:migrate": "ts-node scripts/migrate.ts",
        "db:seed": "ts-node scripts/seed.ts"
    },
    "dependencies": {
        "@psau/shared": "workspace:*",
        "bcrypt": "^5.1.0",
        "better-sqlite3": "^9.6.0",
        "cors": "^2.8.5",
        "express": "^4.19.0",
        "express-rate-limit": "^7.3.0",
        "helmet": "^7.1.0",
        "jsonwebtoken": "^9.0.0",
        "morgan": "^1.10.0",
        "pg": "^8.12.0",
        "winston": "^3.13.0",
        "zod": "^3.25.76"
    },
    "devDependencies": {
        "@types/bcrypt": "^5.0.2",
        "@types/better-sqlite3": "^7.6.13",
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/jsonwebtoken": "^9.0.6",
        "@types/morgan": "^1.9.9",
        "@types/pg": "^8.11.6",
        "dotenv": "^17.3.1",
        "ts-node-dev": "^2.0.0",
        "typescript": "^5.4.0",
        "vitest": "^1.4.0"
    }
}