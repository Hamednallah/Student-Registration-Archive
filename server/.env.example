# Server Configuration
PORT=5000
NODE_ENV=production

# Database Configuration
ORACLE_HOME=D:/app/oracle/product/11.1.0/db_1/BIN
LD_LIBRARY_PATH=C:/instantclient_12_1
DB_HOST=localhost
DB_PORT=1521
DB_USER=SRRA
DB_PASSWORD=your_password_here
DB_CONNECT_STRING=localhost:1521/orcl

# Security Configuration
JWT_SECRET=change_this_to_a_strong_random_secret
JWT_EXPIRES_IN=1h
CORS_ORIGIN=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100

# Session Configuration
SESSION_SECRET=change_this_to_a_strong_random_secret
SESSION_MAX_AGE=3600000

# CSRF Configuration
CSRF_COOKIE_SECURE=true
CSRF_COOKIE_HTTP_ONLY=true 